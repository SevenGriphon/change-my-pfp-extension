{
    "name": "Change my profile picture 42",
    "description": "Extantion that allows user to change their 42 profile picture to an image of their choice",
    "version": "0.0.2",
    "manifest_version": 3,
    "browser_specific_settings": 
    {
        "gecko":
        {
            "data_collection_permissions":
            {
                "required": ["none"]
            },
            "id": "@change_my_pfp"
        }
    },
    "action": {
        "default_icon": "icon.jpg",
        "default_popup": "popup.html"
    },
    "content_scripts":
    [
        {
        "js": ["script.js"],
        "matches": [
            "https://code.42.tech/*"
        ]
        }
    ],
    "background": {
        "service_worker": "background.js",
        "scripts": ["background.js"]
    },
    "permissions": ["activeTab", "storage"]
}